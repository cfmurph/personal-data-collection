{
  "name": "personal-data-hub",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:backend": "cd apps/backend && python3 -m uvicorn app.main:app --reload --port 8000",
    "build:web": "npm run build --workspace=apps/web",
    "build:mobile": "npm run build --workspace=apps/mobile"
  },
  "devDependencies": {
    "turbo": "^2.5.3"
  }
}
